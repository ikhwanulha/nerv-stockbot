# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/nerv_stockbot"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Groq API (AI Chatbot) - Daftar di https://console.groq.com
GROQ_API_KEY="your-groq-api-key"

# Email (for password reset) - Gmail app password recommended
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@nerv-stockbot.com"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
